# Mnemo Proxy env. Copy to .env.

# Networking
PROXY_HOST=0.0.0.0
PROXY_PORT=8080
LOG_LEVEL=INFO

# Infra
DATABASE_URL=postgresql+asyncpg://mnemo_user:mnemo_password@localhost:5432/mnemo_db
REDIS_URL=redis://localhost:6380/0
SIDECAR_URL=http://localhost:3001

# Upstream providers (rarely changed)
OPENAI_BASE_URL=https://api.openai.com
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Capture switch — set to "false" to turn off async memory capture
CAPTURE_ENABLED=true

# WEEK 1 ONLY: fall back to env-supplied provider keys instead of decrypting
# the user's stored key via Seal. Remove in Week 2.
DEV_OPENAI_KEY=
DEV_ANTHROPIC_KEY=
