# Sidecar env. Copy to .env and edit.

PORT=3001
LOG_LEVEL=info

# Sui network: "testnet" or "mainnet"
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Sui address + key for the sidecar's "delegate" wallet. This is the wallet
# that signs Walrus writes on behalf of users (paid by the sponsor account).
# For Week 1, leave blank — we use a mock MemWal client.
# For Week 2+: generate via `sui client new-address ed25519`, export the
# keypair, and paste the base64-encoded private key here.
SIDECAR_DELEGATE_SUI_KEY=

# Mnemo Move package ID (from packages/move/DEPLOYMENTS.md after publish)
MNEMO_PACKAGE_ID=
