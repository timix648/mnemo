# apps/web/.env.example
#
# Copy this to apps/web/.env.local and fill in the real values. Restart the
# Next dev server after any change — env vars are baked at build time.
#
# All NEXT_PUBLIC_* vars are exposed to the browser. Never put secrets here;
# secrets (e.g. ENOKI_SECRET_KEY) belong only on the backend.

# -----------------------------------------------------------------------------
# Enoki — sponsors gas and runs zkLogin so users don't need a Sui wallet.
# Get this from https://portal.enoki.mystenlabs.com → your app → API Keys.
# Use the PUBLIC key (starts with `enoki_public_…`). The key must have
# zkLogin AND Sponsored Transactions enabled, both for testnet.
# A 401 on createAuthorizationURL almost always means this key is wrong,
# disabled, or doesn't have zkLogin enabled.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ENOKI_API_KEY=enoki_public_REPLACE_ME

# -----------------------------------------------------------------------------
# Google OAuth — the client ID for "Sign in with Google".
# Get this from https://console.cloud.google.com → APIs & Services → Credentials
# → OAuth 2.0 Client ID (Web application).
#
# This SAME client ID must also be registered in the Enoki Portal under
# Auth Providers → Google. If they don't match, Enoki returns 401.
#
# Authorized JavaScript origins must include:   http://localhost:3000
# Authorized redirect URIs must include:        http://localhost:3000/auth/callback
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com

# -----------------------------------------------------------------------------
# Optional: point inheritance/heartbeat at a known on-chain account for demos
# (skips the registry lookup). Leave blank in normal use.
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_MNEMO_ACCOUNT_ID=0x...
